# ── Required ────────────────────────────────────────────────────────────
# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# ── Waitlist (Google Apps Script) ───────────────────────────────────────
# Web app deployment URL from Google Apps Script (see README.md)
NEXT_PUBLIC_APPS_SCRIPT_URL=

# ── App URL ─────────────────────────────────────────────────────────────
# Used for server-side references. Set to your deployment URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
